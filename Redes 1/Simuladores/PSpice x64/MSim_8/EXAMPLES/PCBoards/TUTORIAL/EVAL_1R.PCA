*netrules
0.008000 0.008000 0.008000 rnd-040-020
@rule general BASIC traceGrid - - - - 0.001000 0.000000
@rule general BASIC viaGrid - - - - 0.001000 0.000000
@rule DOFILEEND DFM miter - - - - 0.000000 0.000000
@rule DOFILEEND DFM spreadTraces - - - - 0.000000 0.000000
@rule net BASICNET net_trace_width DIG_GND - - - 0.025000 0.000000
@rule net BASICNET net_clearance DIG_GND - - - 0.010000 0.000000
@rule net BASICNET net_trace_width DIG_PWR - - - 0.025000 0.000000
@rule net BASICNET net_clearance DIG_PWR - - - 0.010000 0.000000
*CAM
NCD -- 2 4 trailing
NCDsymbol cr+ 1
textStyle NCDsymbol 0.05 0.001 0 6 0.01
PP -5c3 RS274X 2 4 trailing
PRN bf
*DRC 0.012 0.006 0.008 0.01 0.01 0.01

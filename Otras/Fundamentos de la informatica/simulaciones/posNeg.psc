Algoritmo posNeg
	Definir a como real
	Definir b como texto	
	// 
	Escribir "ingrese s para continuar"
	Leer b
	Mientras b="s" Hacer
		Escribir "ingrese a"
		Leer a
		Si a>0 Entonces
			Escribir "el numero es positivo"
		SiNo
			Escribir "el numero es negativo"
		FinSi
		Escribir "ingrese s para continuar o otra para salir"
		Leer b
	FinMientras
FinAlgoritmo
